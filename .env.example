YANDEX_AI_STUDIO_BASE_URL=https://llm.api.cloud.yandex.net/v1
YANDEX_EMBEDDING_BASE_URL=https://llm.api.cloud.yandex.net:443/foundationModels/v1/textEmbedding

YANDEX_API_KEY=replace_with_service_account_api_key
YANDEX_FOLDER_ID=replace_with_folder_id

YANDEX_QWEN_MODEL=gpt://replace_with_folder_id/qwen3.6-35b-a3b/latest

YANDEX_EMBEDDING_DOC_MODEL=emb://replace_with_folder_id/text-search-doc/latest
YANDEX_EMBEDDING_QUERY_MODEL=emb://replace_with_folder_id/text-search-query/latest
YANDEX_EMBEDDING_DIMENSIONS=256

# Phase 2 jury/eval/UI runtime must use shared Qdrant server mode.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=phase1_source_cards
QDRANT_MODE=local
# Local embedded mode is only for small tests or explicit fallback.
QDRANT_PATH=.local/qdrant
QDRANT_DISTANCE=cosine
